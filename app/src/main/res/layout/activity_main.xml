<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:weightSum="10"
    tools:context=".MainActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:elevation="8dp"
        android:background="#1E1E1E"
        android:padding="10dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="LuxMundi Calculator"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFA500"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name: Daramola Oluwasemiloore Victor"
            android:textSize="18sp"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Matric Number: CSC/2025/166"
            android:textSize="18sp"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Part: 1"
            android:textSize="18sp"
            android:textColor="#FFFFFF" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvsec"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/display_bg"        android:text=""
        android:textColor="#f6f6f6"
        android:textSize="30sp"
        android:textAlignment="viewEnd"
        android:padding="10dp"
        android:gravity="bottom"
        android:maxLines="1" >

    </TextView>

    <TextView
        android:id="@+id/tvmain"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:background="@drawable/display_bg"
        android:text=""
        android:textColor="#fff"
        android:textSize="50sp"
        android:textAlignment="viewEnd"
        android:padding="10dp"
        android:gravity="bottom"
        android:maxLines="1" >

    </TextView>
    <LinearLayout
        android:layout_weight="7"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="0dp" >
        <LinearLayout
            android:orientation="vertical"
            android:weightSum="7"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:orientation="horizontal"
                    android:weightSum="4"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <android.widget.Button
                        android:id="@+id/bac"
                        android:layout_margin="1dp"
                        android:elevation="2dp"
                        android:text="AC"
                        android:textSize="30sp"
                        android:background="@drawable/operator_button_bg"                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </android.widget.Button>
                    <android.widget.Button
                        android:id="@+id/bc"
                        android:layout_margin="1dp"
                        android:elevation="2dp"
                        android:text="C"
                        android:textSize="30sp"
                        android:background="@drawable/operator_button_bg"                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </android.widget.Button>
                    <android.widget.Button
                        android:id="@+id/bb1"
                        android:layout_margin="1dp"
                        android:elevation="2dp"
                        android:text="("
                        android:textSize="30sp"
                        android:background="@drawable/operator_button_bg"                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </android.widget.Button>
                    <android.widget.Button
                        android:id="@+id/bb2"
                        android:layout_margin="1dp"
                        android:elevation="2dp"
                        android:text=")"
                        android:textSize="30sp"
                        android:background="@drawable/operator_button_bg"                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </android.widget.Button>

                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:orientation="horizontal"
                    android:weightSum="5"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <android.widget.Button
                        android:id="@+id/bsin"
                        android:layout_margin="1dp"
                        android:elevation="2dp"
                        android:text="sin"
                        android:textAllCaps="false"
                        android:textSize="30sp"
                        android:background="@drawable/operator_button_bg"                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </android.widget.Button>
                    <android.widget.Button
                        android:id="@+id/bcos"
                        android:layout_margin="1dp"
                        android:elevation="2dp"
                        android:text="cos"
                        android:textAllCaps="false"
                        android:textSize="30sp"
                        android:background="@drawable/operator_button_bg"                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </android.widget.Button>
                    <android.widget.Button
                        android:id="@+id/btan"
                        android:layout_margin="1dp"
                        android:elevation="2dp"
                        android:text="tan"
                        android:textAllCaps="false"
                        android:textSize="30sp"
                        android:background="@drawable/operator_button_bg"                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </android.widget.Button>
                    <android.widget.Button
                        android:id="@+id/blog"
                        android:layout_margin="1dp"
                        android:elevation="2dp"
                        android:text="log"
                        android:textAllCaps="false"
                        android:textSize="30sp"
                        android:background="@drawable/operator_button_bg"
                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </android.widget.Button>
                    <android.widget.Button
                        android:id="@+id/bln"
                        android:text="1n"
                        android:layout_margin="1dp"
android:elevation="2dp"
                        android:textAllCaps="false"
                        android:textSize="30sp"
                        android:background="@drawable/operator_button_bg"                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </android.widget.Button>

                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:orientation="horizontal"
                    android:weightSum="5"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <android.widget.Button
                        android:id="@+id/bfact"
                        android:text="x!"
                        android:textAllCaps="false"
                        android:textSize="30sp"
                        android:background="@drawable/operator_button_bg"                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </android.widget.Button>
                    <android.widget.Button
                        android:id="@+id/bsquare"
                        android:text="x²"
                        android:textAllCaps="false"
                        android:textSize="30sp"
                        android:background="@drawable/operator_button_bg"                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </android.widget.Button>
                    <android.widget.Button
                        android:id="@+id/bsqrt"
                        android:text="√"
                        android:textAllCaps="false"
                        android:textSize="30sp"
                        android:background="@drawable/operator_button_bg"                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </android.widget.Button>
                    <android.widget.Button
                        android:id="@+id/binv"
                        android:text="1/x"
                        android:textAllCaps="false"
                        android:textSize="30sp"
                        android:background="@drawable/operator_button_bg"                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </android.widget.Button>
                    <android.widget.Button
                        android:id="@+id/bdiv"
                        android:text="÷"
                        android:textAllCaps="false"
                        android:textSize="30sp"
                        android:background="@drawable/button_bd"                        android:textColor="#ffa500"
                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </android.widget.Button>

                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:orientation="horizontal"
                    android:weightSum="4"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/b7"
                        android:layout_margin="1dp"
                        android:elevation="2dp"
                        android:text="7"
                        android:textSize="30sp"
                        android:background="@drawable/button_bd"                        android:textColor="#fff"
                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </com.google.android.material.button.MaterialButton>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/b8"
                        android:layout_margin="1dp"
                        android:elevation="2dp"
                        android:text="8"
                        android:textSize="30sp"
                        android:background="@drawable/button_bd"                        android:textColor="#fff"
                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </com.google.android.material.button.MaterialButton>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/b9"
                        android:layout_margin="1dp"
                        android:elevation="2dp"
                        android:text="9"
                        android:textSize="30sp"
                        android:background="@drawable/button_bd"                        android:textColor="#fff"
                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </com.google.android.material.button.MaterialButton>
                    <android.widget.Button
                        android:id="@+id/bmul"
                        android:layout_margin="1dp"
android:elevation="2dp"
                        android:text="×"
                        android:textSize="30sp"
                        android:background="@drawable/button_bd"                        android:textColor="#ffa500"
                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </android.widget.Button>

                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:orientation="horizontal"
                    android:weightSum="4"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/b4"
                        android:layout_margin="1dp"
                        android:elevation="2dp"
                        android:text="4"
                        android:textSize="30sp"
                        android:background="@drawable/button_bd"                        android:textColor="#fff"
                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </com.google.android.material.button.MaterialButton>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/b5"
                        android:layout_margin="1dp"
                        android:elevation="2dp"
                        android:text="5"
                        android:textSize="30sp"
                        android:background="@drawable/button_bd"                        android:textColor="#fff"
                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </com.google.android.material.button.MaterialButton>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/b6"
                        android:layout_margin="1dp"
                        android:elevation="2dp"
                        android:text="6"
                        android:textSize="30sp"
                        android:background="@drawable/button_bd"                        android:textColor="#fff"
                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </com.google.android.material.button.MaterialButton>
                    <android.widget.Button
                        android:id="@+id/bmin"
                        android:layout_margin="1dp"
android:elevation="2dp"
                        android:text="-"
                        android:textSize="30sp"
                        android:background="@drawable/button_bd"                        android:textColor="#ffa500"
                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </android.widget.Button>

                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:orientation="horizontal"
                    android:weightSum="4"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/b1"
                        android:layout_margin="1dp"
                        android:elevation="2dp"
                        android:text="1"
                        android:textSize="30sp"
                        android:background="@drawable/button_bd"                        android:textColor="#fff"
                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </com.google.android.material.button.MaterialButton>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/b2"
                        android:layout_margin="1dp"
                        android:elevation="2dp"
                        android:text="2"
                        android:textSize="30sp"
                        android:background="@drawable/button_bd"                        android:textColor="#fff"
                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </com.google.android.material.button.MaterialButton>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/b3"
                        android:layout_margin="1dp"
                        android:elevation="2dp"
                        android:text="3"
                        android:textSize="30sp"
                        android:background="@drawable/button_bd"                        android:textColor="#fff"
                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </com.google.android.material.button.MaterialButton>
                    <android.widget.Button
                        android:id="@+id/bplus"
                        android:layout_margin="1dp"
android:elevation="2dp"
                        android:text="+"
                        android:textSize="30sp"
                        android:background="@drawable/button_bd"                        android:textColor="#ffa500"
                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </android.widget.Button>

                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:orientation="horizontal"
                    android:weightSum="4"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/bpi"
                        android:layout_margin="1dp"
                        android:elevation="2dp"
                        android:text="π"
                        android:textSize="30sp"
                        android:textAllCaps="false"
                        android:background="@drawable/button_bd"                        android:textColor="#fff"
                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </com.google.android.material.button.MaterialButton>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/b0"
                        android:layout_margin="1dp"
                        android:elevation="2dp"
                        android:text="0"
                        android:textSize="30sp"
                        android:background="@drawable/button_bd"                        android:textColor="#fff"
                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </com.google.android.material.button.MaterialButton>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/bdot"
                        android:layout_margin="1dp"
                        android:elevation="2dp"
                        android:text="."
                        android:textSize="30sp"
                        android:background="@drawable/button_bd"                        android:textColor="#fff"
                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </com.google.android.material.button.MaterialButton>
                    <android.widget.Button
                        android:id="@+id/bequal"
                        android:layout_margin="1dp"
android:elevation="2dp"
                        android:text="="
                        android:textSize="30sp"
                        android:background="@drawable/button_bd"                        android:textColor="#ffa500"
                        android:layout_weight="1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </android.widget.Button>

                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>



</LinearLayout>